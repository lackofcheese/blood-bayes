digraph PlayerRaceConceptMap {
  graph [
    rankdir=LR,
    bgcolor="#ffffff",
    pad="0.35",
    nodesep="0.35",
    ranksep="0.75",
    splines=polyline,
    compound=true,
    newrank=true,
    fontname="Arial",
    fontsize=18,
    label="Coach, race choice, and performance — conceptual map\nInformal discussion canvas; broader than the implemented model",
    labelloc=t,
    labeljust=l
  ];

  node [
    shape=box,
    style="rounded,filled",
    fontname="Arial",
    fontsize=10,
    margin="0.12,0.08",
    color="#555555",
    penwidth=1.2
  ];

  edge [
    color="#66717c",
    penwidth=1.1,
    arrowsize=0.85,
    fontname="Arial",
    fontsize=8,
    fontcolor="#4b5560"
  ];

  subgraph cluster_context {
    label="PACK, RACE, AND SOCIAL CONTEXT";
    color="#d7ae4c";
    fillcolor="#fff8e3";
    fontcolor="#6d4b00";
    fontsize=11;
    style="rounded,filled";

    pack [label="Pack treatment\nresources · legality · scoring", fillcolor="#fff1c9", color="#9b6a00"];
    race [label="Race style geometry\nBash · Ag · Stunty / unusual mechanics", fillcolor="#fff1c9", color="#9b6a00"];
    difficulty [label="Entry and mastery\ndifficulty", fillcolor="#fff1c9", color="#9b6a00"];
    meta [label="Region · community\npublic meta", fillcolor="#fff1c9", color="#9b6a00"];
    format [label="Event format\nopen or squad", fillcolor="#fff1c9", color="#9b6a00"];
    field [label="Expected field\nand opponents", fillcolor="#fff1c9", color="#9b6a00"];
    favorability [label="Perceived pack / field\nfavorability", fillcolor="#fff1c9", color="#9b6a00"];
  }

  subgraph cluster_traits {
    label="RELATIVELY PERSISTENT COACH CHARACTERISTICS";
    color="#9673ca";
    fillcolor="#f7f1ff";
    fontcolor="#56338e";
    fontsize=11;
    style="rounded,filled";

    talent [label="General game talent\nplanning · calculation · risk judgement", fillcolor="#eadfff", color="#6842a6"];
    style_aptitude [label="Style-specific\naptitude", fillcolor="#eadfff", color="#6842a6"];
    learning [label="Learning capacity\nand ceiling", fillcolor="#eadfff", color="#6842a6"];
    investment [label="Competitive investment\ntime · preparation · optimisation", fillcolor="#eadfff", color="#6842a6"];
    preference [label="Style and exact-race\npreference", fillcolor="#eadfff", color="#6842a6"];
    exploration [label="Exploration / switching\ndisposition", fillcolor="#eadfff", color="#6842a6"];
    resources [label="Material and social resources\nmoney · storage · friends · borrowing", fillcolor="#eadfff", color="#6842a6"];
  }

  subgraph cluster_state {
    label="LATENT COACH STATE BEFORE THE EVENT";
    color="#6096c8";
    fillcolor="#eff7ff";
    fontcolor="#235d93";
    fontsize=11;
    style="rounded,filled";

    general_ability [label="Current general\nability", fillcolor="#dcecff", color="#2867a3"];
    hidden_experience [label="Hidden experience\nleague · online · casual · earlier play", fillcolor="#dcecff", color="#2867a3"];
    naf_play [label="Prior NAF\ntournament play", fillcolor="#dcecff", color="#2867a3"];
    total_experience [label="Total race-specific\nexperience", fillcolor="#dcecff", color="#2867a3"];
    style_experience [label="Transferable style\nexperience", fillcolor="#dcecff", color="#2867a3"];
    competence [
      label="COACH–RACE COMPETENCE\npersonal expected strength on this race",
      fillcolor="#ccecff",
      color="#004f87",
      penwidth=3.0,
      fontsize=11
    ];
    access [label="Practical race access", fillcolor="#dcecff", color="#2867a3"];
    loyalty [label="Current loyalty\nand attachment", fillcolor="#dcecff", color="#2867a3"];
    adaptation [label="Competitive adaptation\nresponse to an available edge", fillcolor="#dcecff", color="#2867a3"];
  }

  subgraph cluster_current {
    label="CURRENT EVENT t";
    color="#c76a7e";
    fillcolor="#fff3f5";
    fontcolor="#8d2940";
    fontsize=11;
    style="rounded,filled";

    choice [label="Race chosen\nor assigned", fillcolor="#ffe0e6", color="#9d3850", penwidth=2.0];
    build [label="Realised roster\nand build", fillcolor="#ffe0e6", color="#9d3850"];
    pairing [label="Opponent · pairing\nand matchup", fillcolor="#ffe0e6", color="#9d3850"];
    performance [label="Latent match\nperformance", fillcolor="#ffe0e6", color="#9d3850", penwidth=2.0];
    outcome [label="Observed W / D / L\noptional TD / CAS", fillcolor="#ffe0e6", color="#9d3850"];
  }

  future [
    label="LATER EVENT t+1\nupdated experience · access · loyalty\nbeliefs and ability",
    fillcolor="#eeeeee",
    color="#666666",
    penwidth=1.5
  ];

  /* Race, pack, and field structure */
  race -> difficulty;
  race -> style_experience;
  race -> pairing;
  pack -> favorability;
  pack -> build;
  pack -> performance;
  meta -> favorability;
  meta -> field;
  meta -> access;
  format -> choice [headport=s, color="#a34259"];
  format -> pairing;
  field -> favorability;
  field -> pairing;

  /* Formation of ability and preparedness */
  talent -> general_ability;
  style_aptitude -> competence;
  learning -> competence;
  investment -> general_ability;
  investment -> hidden_experience;
  investment -> adaptation;
  hidden_experience -> total_experience;
  naf_play -> total_experience;
  total_experience -> competence;
  total_experience -> style_experience;
  style_experience -> competence;
  general_ability -> competence;
  difficulty -> competence;

  /* Preference, access, and switching */
  preference -> loyalty;
  exploration -> adaptation;
  resources -> access;

  /* Joint choice and performance heart */
  access -> choice [headport=sw, color="#a34259"];
  loyalty -> choice [headport=n, color="#a34259"];
  adaptation -> choice [headport=nw, color="#a34259"];
  favorability -> choice [headport=s, color="#a34259"];
  competence -> choice [headport=w, color="#004f87", penwidth=2.5];
  choice -> build [tailport=e, headport=w];
  build -> performance [tailport=e, headport=w, color="#8d4960"];
  competence -> performance [headport=nw, color="#004f87", penwidth=2.5];
  pairing -> performance [headport=sw, color="#8d4960"];
  performance -> outcome;

  /* Explicit event-t to event-t+1 feedback */
  choice -> future;
  outcome -> future;

}
