digraph PlayerRaceProcessMap {
  graph [
    rankdir=LR,
    bgcolor="#ffffff",
    pad="0.30",
    nodesep="0.38",
    ranksep="0.88",
    splines=polyline,
    compound=true,
    newrank=true,
    outputorder=edgesfirst,
    fontname="Arial",
    fontsize=20,
    label="Gold-standard coach race-selection and tournament-performance DAG\nQualitative generative hypothesis — not all nodes are identifiable or explicitly fitted",
    labelloc=t,
    labeljust=l
  ];

  node [
    shape=box,
    style="rounded,filled",
    fontname="Arial",
    fontsize=10.5,
    margin="0.15,0.09",
    color="#555f69",
    penwidth=1.3
  ];

  edge [
    color="#65717d",
    penwidth=1.15,
    arrowsize=0.82,
    fontname="Arial",
    fontsize=8.5,
    fontcolor="#46515c"
  ];

  subgraph cluster_upstream {
    label="UPSTREAM CONTEXT AND PRIOR STATE";
    color="#8562b5";
    fillcolor="#f8f2ff";
    fontcolor="#56338e";
    fontsize=13;
    penwidth=1.4;
    style="rounded,filled";

    organizer_context [
      label="Organiser goals · event identity\nregion and local community",
      fillcolor="#fff1c9", color="#9b6a00"
    ];
    coach_traits [
      label="Persistent coach traits\ngeneral talent · style aptitude · learning capacity\ncompetitive investment · adaptation disposition",
      fillcolor="#eadfff", color="#6842a6"
    ];
    prior_history [
      label="Prior play and results\nNAF · league · online · casual",
      fillcolor="#eadfff", color="#6842a6"
    ];
    access [
      label="Practical race access\nminiatures · borrowing · money · preparation feasibility",
      fillcolor="#eadfff", color="#6842a6"
    ];
    preference [
      label="Style and exact-race preference\nloyalty · switching disposition",
      fillcolor="#eadfff", color="#6842a6"
    ];
    attendance_factors [
      label="Attendance resources and incentives\ntravel · money · time · prestige · event appeal",
      fillcolor="#eadfff", color="#6842a6"
    ];
  }

  subgraph cluster_preevent {
    label="BEFORE EVENT t";
    color="#4f8fc5";
    fillcolor="#eff7ff";
    fontcolor="#235d93";
    fontsize=13;
    penwidth=1.4;
    style="rounded,filled";

    pack [
      label="Rules pack and event format\nlegality · resources · scoring · open/squad",
      fillcolor="#fff1c9", color="#9b6a00"
    ];
    attendance [
      label="Attendance decision and\nrealised coach pool",
      fillcolor="#dcecff", color="#2867a3"
    ];
    anticipated_field [
      label="Anticipated field and public meta\ninformation available before selection",
      fillcolor="#dcecff", color="#2867a3"
    ];
    preparation [
      label="Event-specific preparation\nand current engagement",
      fillcolor="#dcecff", color="#2867a3"
    ];
    preparedness [
      label="ACTUAL PRE-EVENT\nCOACH–RACE PREPAREDNESS",
      fillcolor="#ccecff", color="#004f87", penwidth=2.8
    ];
    perceived_fit [
      label="Coach/captain belief about\npersonal coach–race fit",
      fillcolor="#dcecff", color="#2867a3"
    ];
  }

  subgraph cluster_selection {
    label="SELECTION OR ASSIGNMENT";
    color="#b45a70";
    fillcolor="#fff3f5";
    fontcolor="#8d2940";
    fontsize=13;
    penwidth=1.4;
    style="rounded,filled";

    available_choices [
      label="Available races and\nsquad-wide constraints",
      fillcolor="#ffe0e6", color="#9d3850"
    ];
    perceived_advantage [
      label="Perceived competitive advantage\npack fit · field fit · personal fit",
      fillcolor="#ffe0e6", color="#9d3850"
    ];
    selection [
      label="Coach choice or captain/squad assignment\ndecision-maker depends on event format",
      fillcolor="#ffd2dc", color="#8d2940", penwidth=2.4
    ];
  }

  subgraph cluster_realised {
    label="REALISED TOURNAMENT";
    color="#b17819";
    fillcolor="#fff8e3";
    fontcolor="#77500a";
    fontsize=13;
    penwidth=1.4;
    style="rounded,filled";

    race_played [label="Race played", fillcolor="#fff1c9", color="#9b6a00"];
    realised_field [
      label="Aggregate selections and\nrealised field",
      fillcolor="#fff1c9", color="#9b6a00"
    ];
    own_build [
      label="Own realised roster/build\nresources · skills · stars · inducements",
      fillcolor="#fff1c9", color="#9b6a00"
    ];
    prior_round_state [
      label="Current round state\nstandings and previous results",
      fillcolor="#fff1c9", color="#9b6a00"
    ];
    pairing [
      label="Pairing and opponent\nformat · standings · realised field",
      fillcolor="#fff1c9", color="#9b6a00"
    ];
    matchup [
      label="Actual matchup\nboth races, builds, and coaches",
      fillcolor="#fff1c9", color="#9b6a00"
    ];
    opponent_state [
      label="Opponent preparedness\nrace and realised build\n(mirrored generative branch)",
      fillcolor="#fff1c9", color="#9b6a00"
    ];
  }

  subgraph cluster_outcome {
    label="PERFORMANCE, OBSERVATION, AND TIME";
    color="#6f7d89";
    fillcolor="#f4f5f6";
    fontcolor="#46515c";
    fontsize=13;
    penwidth=1.4;
    style="rounded,filled";

    strategy [
      label="Match strategy / decisiveness\nincluding scoring incentives",
      fillcolor="#eeeeee", color="#68737d"
    ];
    expected_performance [
      label="Relative expected\nmatch performance",
      fillcolor="#e5e9ec", color="#46515c", penwidth=2.3
    ];
    stochasticity [
      label="Game stochasticity\ndice · kick-offs · weather · game-state path",
      fillcolor="#eeeeee", color="#68737d"
    ];
    realised_outcome [
      label="Realised game outcome",
      fillcolor="#e5e9ec", color="#46515c", penwidth=2.0
    ];
    recorded_result [
      label="Recorded observation\nW / D / L · optional TD / CAS",
      fillcolor="#e5e9ec", color="#46515c", penwidth=2.0
    ];
    next_round [
      label="Round state at k+1\nstandings · progression · pairing inputs",
      fillcolor="#eeeeee", color="#68737d"
    ];
    next_event [
      label="Pre-event state at t+1\nexperience · beliefs · loyalty · access",
      fillcolor="#eeeeee", color="#68737d"
    ];
  }

  /* Context, attendance selection, and state formation. */
  organizer_context:e -> pack:w [color="#9b6a00"];
  organizer_context:e -> anticipated_field:w;
  attendance_factors:e -> attendance:w;
  pack:e -> attendance:w [label="appeal"];
  attendance:e -> anticipated_field:w;
  coach_traits:e -> preparation:w;
  prior_history:e -> preparation:w;
  coach_traits:e -> preparedness:w [color="#004f87", penwidth=1.8];
  prior_history:e -> preparedness:w [color="#004f87", penwidth=1.8];
  preparation:e -> preparedness:w [color="#004f87", penwidth=1.8];

  /* Actual preparedness and the decision-maker's belief are distinct. */
  preparedness:e -> perceived_fit:w [color="#004f87", penwidth=1.8];
  prior_history:e -> perceived_fit:w [label="information"];

  /* Choice or assignment. Actual preparedness acts through belief. */
  pack:e -> available_choices:w [color="#a34259"];
  pack:e -> perceived_advantage:w [color="#a34259"];
  anticipated_field:e -> perceived_advantage:w [color="#a34259"];
  perceived_fit:e -> perceived_advantage:w [color="#a34259"];
  access:e -> selection:w [color="#a34259"];
  preference:e -> selection:w [color="#a34259"];
  coach_traits:e -> selection:w [label="adaptation", color="#a34259"];
  attendance:e -> selection:w [label="in observed pool", color="#a34259"];
  available_choices:e -> selection:w [color="#a34259"];
  perceived_advantage:e -> selection:w [color="#a34259"];

  /* Aggregate selections create the field; expectations do not pair games. */
  selection:e -> race_played:w [color="#8d2940", penwidth=2.0];
  attendance:e -> realised_field:w;
  race_played:e -> realised_field:w [label="aggregate"];
  race_played:e -> own_build:w;
  pack:e -> own_build:w;
  preparation:e -> own_build:w;
  anticipated_field:e -> own_build:w [label="preparation target"];
  realised_field:e -> pairing:w;
  pack:e -> pairing:w [label="format"];
  prior_round_state:e -> pairing:w;
  pairing:e -> matchup:w;
  race_played:e -> matchup:w;
  own_build:e -> matchup:w;
  opponent_state:e -> matchup:w;

  /* Expected performance, stochastic realisation, and observation. */
  pack:e -> strategy:w [label="scoring"];
  matchup:e -> strategy:w;
  preparedness:e -> expected_performance:w [color="#004f87", penwidth=2.5];
  matchup:e -> expected_performance:w [color="#77500a", penwidth=1.7];
  strategy:e -> expected_performance:w;
  opponent_state:e -> expected_performance:w;
  expected_performance:e -> realised_outcome:w [color="#46515c", penwidth=2.2];
  stochasticity:e -> realised_outcome:w;
  realised_outcome:e -> recorded_result:w;

  /* All feedback crosses an explicit round or event boundary, preserving acyclicity. */
  recorded_result:e -> next_round:w;
  recorded_result:e -> next_event:w;
  race_played:e -> next_event:w [label="experience"];

  { rank=same; organizer_context; coach_traits; prior_history; access; preference; attendance_factors; }
  { rank=same; pack; attendance; anticipated_field; preparation; preparedness; perceived_fit; }
  { rank=same; available_choices; perceived_advantage; selection; }
  { rank=same; race_played; realised_field; own_build; prior_round_state; pairing; matchup; opponent_state; }
  { rank=same; strategy; expected_performance; stochasticity; realised_outcome; recorded_result; next_round; next_event; }
}
